# Copy to .env and adjust as needed.

# Default (zero-config): local SQLite file
DATABASE_URL=sqlite:///./formplatform.db

# To use PostgreSQL (matches the intended stack; also used by docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://formuser:formpass@localhost:5432/formplatform

CORS_ORIGINS=*
PUBLIC_BASE_URL=http://localhost:5173
